%% 12. DIMENSIONALITY REDUCTION METHODS (Section 3.6)
fprintf('\n============================================================\n');
fprintf('STARTING DIMENSIONALITY REDUCTION ANALYSIS\n');
fprintf('============================================================\n');

% Prepare categorical labels for plots
class_names = {'Rest', 'Task'};
target_labels = categorical(y_train, [1, 2], class_names);

% --- 1. PCA (Principal Component Analysis) ---
tic;
[coeff, score, latent, tsquared, explained] = pca(X_train_final);
cum_explained = cumsum(explained);
time_pca = toc;

fprintf('\n>>> 1. PCA Report <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_pca);
fprintf('Cumulative Variance Explained (First 3 Components): %.2f%%\n', cum_explained(min(3, end)));

% Plot Scree and Cumulative Variance
figure('Name', 'PCA Analysis', 'Units', 'normalized', 'Position', [0.1 0.1 0.4 0.4]);
yyaxis left
bar(explained, 'FaceColor', [0.7 0.7 0.7]); ylabel('Individual Variance (%)');
yyaxis right
plot(cum_explained, '-o', 'LineWidth', 1.5); ylabel('Cumulative Variance (%)');
grid on; xlabel('Principal Component'); title('PCA: Scree & Cumulative Variance Plot');

% --- 2. LDA (Linear Discriminant Analysis) ---
tic;
% LDA is supervised; it maximizes class separability
% To get eigenvalues, we calculate the Scatter Matrices manually
group1 = X_train_final(y_train == 1, :);
group2 = X_train_final(y_train == 2, :);

% Mean of each class and global mean
mu1 = mean(group1);
mu2 = mean(group2);
muTotal = mean(X_train_final);

% Between-class scatter matrix (Sb)
Sb = (size(group1,1)*(mu1 - muTotal)'*(mu1 - muTotal)) + ...
     (size(group2,1)*(mu2 - muTotal)'*(mu2 - muTotal));

% Within-class scatter matrix (Sw)
Sw = cov(group1)*(size(group1,1)-1) + cov(group2)*(size(group2,1)-1);

% Solve for Eigenvalues (Discrimination Power)
% We solve the generalized eigenvalue problem: Sb*v = lambda*Sw*v
lda_eigenvalues = eig(Sb, Sw);
% For 2 classes, there is only 1 non-zero eigenvalue
max_lda_eig = max(lda_eigenvalues);

% Get the scores for plotting using fitcdiscr
Mdl_lda = fitcdiscr(X_train_final, y_train);
[~, lda_score] = predict(Mdl_lda, X_train_final); 
% For binary LDA, the second column of 'score' represents the discriminant axis
lda_projection = lda_score(:,2) - lda_score(:,1); 

time_lda = toc;

fprintf('\n>>> 2. LDA Report <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_lda);
fprintf('Principal Eigenvalue (Discrimination Power): %.4f\n', max_lda_eig);
% --- 3. ICA (Independent Component Analysis) ---
tic;
% Using 'rica' (Reconstruction ICA) for source separation
num_ica_comp = 3; 
Mdl_ica = rica(X_train_final, num_ica_comp);
ica_score = transform(Mdl_ica, X_train_final);
time_ica = toc;

fprintf('\n>>> 3. ICA Report <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_ica);
fprintf('ICA components extracted: %d\n', num_ica_comp);

% --- 4. t-SNE (t-Distributed Stochastic Neighbor Embedding) ---
tic;
% Non-linear visualization method
tsne_score = tsne(X_train_final, 'Algorithm', 'exact', 'Distance', 'euclidean');
time_tsne = toc;

fprintf('\n>>> 4. t-SNE Report <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_tsne);

% --- 5. Kernel PCA (Non-linear PCA) ---
tic;
% Testing RBF (Gaussian) Kernel
% Note: Standard PCA is on the kernel matrix
K = exp(-pdist2(X_train_final, X_train_final).^2 ./ (2 * size(X_train_final, 2)));
% Center the kernel matrix
N = size(K, 1);
one_n = ones(N, N) / N;
K_centered = K - one_n * K - K * one_n + one_n * K * one_n;
[k_vectors, k_values] = eigs(K_centered, 2);
kpca_score = K_centered * k_vectors;
time_kpca = toc;

fprintf('\n>>> 5. Kernel PCA Report <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_kpca);
fprintf('Kernel Type: RBF (Gaussian)\n');

% ============================================================
% VISUALIZATION: REDUCED FEATURE SPACES
% ============================================================
figure('Name', 'Dimensionality Reduction Comparison', 'Units', 'normalized', 'Position', [0.1 0.1 0.8 0.7]);
t_layout = tiledlayout(2, 3, 'TileSpacing', 'compact');
title(t_layout, 'Comparison of Dimensionality Reduction Methods (Class Separability)', 'FontSize', 14);

% PCA Scatter
nexttile; gscatter(score(:,1), score(:,2), target_labels, 'rb', 'o+');
title('PCA (2D Projection)'); grid on;

