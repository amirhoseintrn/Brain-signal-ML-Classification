nexttile; bar(mrmr_sorted(1:k_top), 'FaceColor', [0.4 0.8 0.4]);
set(gca, 'XTick', 1:k_top, 'XTickLabel', mrmr_idx(1:k_top)); xtickangle(45); 
title(sprintf('mRMR\nSelected: %d | Time: %.2fs', k_top, time_mrmr));

nexttile; bar(relief_sorted(1:k_top), 'FaceColor', [0.6 0.4 0.8]);
set(gca, 'XTick', 1:k_top, 'XTickLabel', relief_idx(1:k_top)); xtickangle(45); 
title(sprintf('ReliefF\nSelected: %d | Time: %.2fs', k_top, time_relief)); ylabel('Weight');

nexttile; bar(lasso_sorted(1:num_to_show_lasso), 'FaceColor', [0.9 0.7 0.2]);
set(gca, 'XTick', 1:num_to_show_lasso, 'XTickLabel', lasso_idx(1:num_to_show_lasso)); xtickangle(45); 
title(sprintf('LASSO (Abs Coeff)\nSelected: %d | Time: %.2fs', num_lasso_selected, time_lasso));

nexttile; bar(rf_sorted(1:k_top), 'FaceColor', [0.3 0.3 0.3]);
set(gca, 'XTick', 1:k_top, 'XTickLabel', rf_idx(1:k_top)); xtickangle(45); 
title(sprintf('Random Forest\nSelected: %d | Time: %.2fs', k_top, time_rf));
%% 11. ENSEMBLE FEATURE SELECTION (Majority Voting) & SLICING DATA
fprintf('\n============================================================\n');
fprintf('FINAL ENSEMBLE FEATURE SELECTION (VOTING SYSTEM)\n');
fprintf('============================================================\n');

% 1. Collect all top features from the 6 previous methods
% (LASSO is already filtered to only include non-zero weights)
all_selected_features = [fdr_idx(1:k_top)'; 
                         mi_idx(1:k_top)'; 
                         mrmr_idx(1:k_top)'; 
                         relief_idx(1:k_top)'; 
                         lasso_idx(1:num_to_show_lasso)'; 
                         rf_idx(1:k_top)'];

% 2. Count the votes (frequency of occurrence for each feature)
[vote_counts, unique_features] = groupcounts(all_selected_features);

% 3. Sort features in descending order based on the number of votes
[sorted_votes, sort_indices] = sort(vote_counts, 'descend');
sorted_feature_ids = unique_features(sort_indices);

% 4. Select the final top 20 features with the highest votes
num_final_features = min(20, length(sorted_feature_ids));
final_selected_ids = sorted_feature_ids(1:num_final_features);
final_selected_votes = sorted_votes(1:num_final_features);

% 5. Decode feature IDs into readable names
% List of the 20 base features extracted in the process_channel function:
feature_names_list = ["Mean", "Std", "Median", "Skewness", "Kurtosis", "RMS", "ZCR", ...
                      "Hjorth Activity", "Hjorth Mobility", "Hjorth Complexity", ...
                      "Shannon Entropy", "Spectral Entropy", "ApEn(0)", "SampEn(0)", "PermEn(0)", ...
                      "Delta Power (0.5-4 Hz)", "Theta Power (4-8 Hz)", "Alpha Power (8-13 Hz)", ...
                      "Beta Power (13-30 Hz)", "Gamma Power (30-50 Hz)"];

final_feature_names = strings(num_final_features, 1);

for i = 1:num_final_features
    id = final_selected_ids(i);
    
    % Find channel number (divide by 20 and round up)
    channel_num = ceil(id / 20);
    
    % Find the specific feature index (remainder of division)
    feat_idx = mod(id - 1, 20) + 1;
    
    % Combine channel and feature name
    final_feature_names(i) = sprintf('Channel %d - %s', channel_num, feature_names_list(feat_idx));
end

% 6. Create and display the final report table
Final_Report_Table = table(final_selected_ids, final_selected_votes, final_feature_names, ...
    'VariableNames', {'Feature_ID', 'Total_Votes', 'Feature_Name'});

fprintf('✅ The Final Golden Features based on Ensemble Voting:\n\n');
disp(Final_Report_Table);

% 7. Slice the dataset (Reduce dimensionality from 420 to 20 columns)
X_train_final = X_train(:, final_selected_ids);
X_test_final  = X_test(:, final_selected_ids);

fprintf('✅ Dataset successfully sliced!\n');
fprintf('   - New X_train shape: [%d rows x %d columns]\n', size(X_train_final, 1), size(X_train_final, 2));
