
%% CELL 1: CONFIGURATION, DATA LOADING, AND FEATURE EXTRACTION
clear; clc; close all;

% --- Configuration ---
dataPath = 'C:\Users\Asus\Desktop\eeg-during-mental-arithmetic-tasks-1.0.0';
fs = 500;  
window_sec = 2;                     
window_size = fs * window_sec;      
step_size = window_size;            

bands.delta = [0.5, 4];
bands.theta = [4, 8];
bands.alpha = [8, 13];
bands.beta  = [13, 30];
bands.gamma = [30, 50];

% --- Main Execution ---
files = dir(fullfile(dataPath, '*.edf'));
num_files = length(files);
fprintf('Processing %d files...\n', num_files);

X_cell = cell(num_files, 1);
y_cell = cell(num_files, 1);

parfor i = 1:num_files
    file_name = files(i).name;
    file_path = fullfile(dataPath, file_name);
    
    label = 2;
    if contains(file_name, '_1.edf')
        label = 1;
    end
    
    try
        T = edfread(file_path);
        num_channels = min(21, width(T));
        
        first_ch_data = T{:, 1};
        if iscell(first_ch_data), first_ch_data = cell2mat(first_ch_data); end
        n_samples = length(first_ch_data);
        data = zeros(num_channels, n_samples);
        
        for ch = 1:num_channels
            ch_data = T{:, ch};
            if iscell(ch_data), data(ch, :) = cell2mat(ch_data)';
            else, data(ch, :) = ch_data'; end
        end
        
        n_windows = floor(n_samples / window_size);
        file_features = zeros(n_windows, 21 * 20); 
        
        for w = 1:n_windows
            start_idx = (w-1)*step_size + 1;
            end_idx = start_idx + window_size - 1;
            window_data = data(:, start_idx:end_idx);
            
            window_features = zeros(1, 21 * 20);
            for ch = 1:21
                ch_features = process_channel(window_data(ch, :), fs, bands);
                idx_start = (ch-1)*20 + 1;
                idx_end = ch*20;
                window_features(idx_start:idx_end) = ch_features;
            end
            file_features(w, :) = window_features;
        end
        
        X_cell{i} = file_features;
        y_cell{i} = repmat(label, n_windows, 1);
    catch ME
        fprintf('Error processing %s: %s\n', file_name, ME.message);
    end
end

% --- Compilation and Saving ---
X = vertcat(X_cell{:});
y = vertcat(y_cell{:});

fprintf('\n✅ Final feature matrix shape: [%d, %d]\n', size(X, 1), size(X, 2));
save('eeg_features_final.mat', 'X', 'y', '-v7.3');
fprintf('💾 Features saved to: eeg_features_final.mat\n');

%% CELL 2: NORMALIZATION, STATISTICAL ANALYSIS, AND VISUALIZATION
% --- Load Data ---
if ~exist('X', 'var')
    load('eeg_features_final.mat');
end

% --- Splitting and Normalization (Section 3.3) ---
fprintf('\nSplitting data into 80%% Training and 20%% Testing sets...\n');
rng("shuffle"); 
y_cell_char = cellstr(string(y)); 
cv = cvpartition(y_cell_char, 'HoldOut', 0.2);


X_train_raw = X(training(cv), :);
y_train = y(training(cv), :);
X_test_raw = X(test(cv), :);
y_test = y(test(cv), :);

mu_train = mean(X_train_raw);
sigma_train = std(X_train_raw);
sigma_train(sigma_train == 0) = 1; % Prevent division by zero

X_train = (X_train_raw - mu_train) ./ sigma_train;
X_test = (X_test_raw - mu_train) ./ sigma_train;
fprintf('✅ Features properly Z-score normalized based strictly on training statistics.\n');

% --- Statistical Analysis (Section 3.4) ---
num_features = size(X_train, 2);
p_values_t = zeros(num_features, 1);
p_values_mwu = zeros(num_features, 1);

class1_data = X_train(y_train == 1, :); 
class2_data = X_train(y_train == 2, :); 

fprintf('\nComputing p-values for %d features...\n', num_features);
for i = 1:num_features
    [~, p_t] = ttest2(class1_data(:, i), class2_data(:, i));
    p_values_t(i) = p_t;
    p_mwu = ranksum(class1_data(:, i), class2_data(:, i));
    p_values_mwu(i) = p_mwu;
end

sig_level = repmat("Not Sig", num_features, 1);
sig_level(p_values_mwu < 0.05) = "p < 0.05";
sig_level(p_values_mwu < 0.01) = "p < 0.01";
sig_level(p_values_mwu < 0.001) = "p < 0.001";

FeatureIndex = (1:num_features)';
StatsReport = table(FeatureIndex, p_values_t, p_values_mwu, sig_level, ...
    'VariableNames', {'Feature_ID', 'T_Test_pValue', 'MWU_pValue', 'Significance'});

StatsReport = sortrows(StatsReport, 'MWU_pValue');
fprintf('\n✅ Statistical Report generated. Showing the top 15 most discriminative features:\n');
disp(head(StatsReport, 15));

% --- Visualization of Top Features ---
