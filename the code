figure('Name', 'Top Discriminative Features', 'Position', [100, 100, 1200, 800]);
t = tiledlayout(3, 4, 'TileSpacing', 'compact', 'Padding', 'compact');
title(t, 'Distributions of Top 12 Most Discriminative Features (Rest vs Task)', ...
