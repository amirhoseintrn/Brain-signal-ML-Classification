h2 = histogram(lda_score(y_train==2), 'FaceColor', 'b', 'Normalization', 'pdf');
title('LDA: Class Separability'); legend(class_names); grid on;

% ICA Scatter
nexttile; gscatter(ica_score(:,1), ica_score(:,2), target_labels, 'rb', 'o+');
title('ICA (Source Separation)'); grid on;

% t-SNE Scatter
nexttile; gscatter(tsne_score(:,1), tsne_score(:,2), target_labels, 'rb', 'o+');
title('t-SNE (Non-linear Visualization)'); grid on;

% Kernel PCA Scatter
nexttile; gscatter(kpca_score(:,1), kpca_score(:,2), target_labels, 'rb', 'o+');
title('Kernel PCA (RBF Kernel)'); grid on;

% 3D PCA for Analysis
nexttile; scatter3(score(:,1), score(:,2), score(:,3), 15, y_train, 'filled');
colormap([1 0 0; 0 0 1]); view(30, 35);
title('PCA 3D Visualization'); grid on; xlabel('PC1'); ylabel('PC2'); zlabel('PC3');
