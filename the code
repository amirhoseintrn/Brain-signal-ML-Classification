    @(X,y) fitcsvm(X,y, 'KernelFunction', 'rbf');               % 3. SVM
    @(X,y) fitcdiscr(X,y);                                      % 4. LDA
    @(X,y) fitctree(X,y);                                       % 5. Decision Trees
    @(X,y) fitcensemble(X,y, 'Method', 'Bag');                  % 6. Random Forest
    @(X,y) fitcensemble(X,y, 'Method', 'LogitBoost');           % 7. Gradient Boosting
    @(X,y) fitclinear(X,y, 'Learner', 'logistic');              % 8. Logistic Regression
    @(X,y) fitcensemble(X,y, 'Method', 'Subspace', 'Learners', templateKNN('NumNeighbors', 3)) % 9. Ensemble Voting
};

model_names = {'Naive Bayes', 'k-NN', 'SVM', 'LDA', 'Decision Tree', ...
               'Random Forest', 'Gradient Boost', 'Logistic Reg', 'Ensemble Voting'};

% 10-Fold Stratified Cross-Validation setup (Section 3.9)
K = 10;
cvp = cvpartition(y_all, 'KFold', K, 'Stratify', true);

% Metrics storage: [Models x Metrics x Folds]
% Metrics: 1.Acc, 2.Sens, 3.Spec, 4.Prec, 5.F1, 6.AUC, 7.Kappa, 8.MCC
all_results = zeros(length(models), 8, K);

fprintf('Running 10-Fold CV for %d models... Please wait.\n', length(models));

for m = 1:length(models)
    fprintf('-> Training & Evaluating: %s\n', model_names{m});
    for k = 1:K
        % Training and Validation sets for current fold
        X_tr = X_all(cvp.training(k), :);
        y_tr = y_all(cvp.training(k), :);
        X_te = X_all(cvp.test(k), :);
        y_te = y_all(cvp.test(k), :);
        
        % Train model
        mdl = models{m}(X_tr, y_tr);
        
        % Predict
        [y_pred, scores] = predict(mdl, X_te);
        if iscell(y_pred), y_pred = str2double(y_pred); end
        
        % Confusion Matrix metrics
        cp = confusionmat(y_te, y_pred);
        TN = cp(1,1); FP = cp(1,2); FN = cp(2,1); TP = cp(2,2);
        
        % 1. Accuracy
        all_results(m,1,k) = (TP + TN) / (TP + TN + FP + FN);
        % 2. Sensitivity (Recall)
        all_results(m,2,k) = TP / (TP + FN);
        % 3. Specificity
        all_results(m,3,k) = TN / (TN + FP);
        % 4. Precision
        all_results(m,4,k) = TP / (TP + FP);
        % 5. F1-Score
        all_results(m,5,k) = 2 * (all_results(m,4,k) * all_results(m,2,k)) / (all_results(m,4,k) + all_results(m,2,k));
        
        % 6. AUC-ROC (Area under curve)
        [~,~,~,auc] = perfcurve(y_te, scores(:,2), 2);
        all_results(m,6,k) = auc;
        
        % 7. Cohen's Kappa
        p0 = all_results(m,1,k);
        pe = ((TP+FP)*(TP+FN) + (TN+FN)*(TN+FP)) / (length(y_te)^2);
        all_results(m,7,k) = (p0 - pe) / (1 - pe);
        
        % 8. MCC (Matthews Correlation Coefficient)
        num = (TP*TN - FP*FN);
        den = sqrt((TP+FP)*(TP+FN)*(TN+FP)*(TN+FN));
        all_results(m,8,k) = num / max(den, eps);
    end
end

% --- Final Reporting: Mean +/- Std Deviation (Section 3.9 Report Format) ---
fprintf('\n============================================================\n');
fprintf('FINAL REPORT: PERFORMANCE ACROSS 10 FOLDS (Mean +/- STD)\n');
fprintf('============================================================\n');

metric_titles = {'Accuracy', 'Sensitivity', 'Specificity', 'Precision', 'F1_Score', 'AUC_ROC', 'Kappa', 'MCC'};
final_table_data = strings(length(models), length(metric_titles));

for m = 1:length(models)
    for j = 1:length(metric_titles)
        m_val = mean(all_results(m,j,:), 'omitnan');
        s_val = std(all_results(m,j,:), 'omitnan');
        final_table_data(m,j) = sprintf('%.3f ± %.3f', m_val, s_val);
    end
end

T_final = table(final_table_data(:,1), final_table_data(:,2), final_table_data(:,3), ...
                final_table_data(:,4), final_table_data(:,5), final_table_data(:,6), ...
                final_table_data(:,7), final_table_data(:,8), ...
                'RowNames', model_names, 'VariableNames', metric_titles);
disp(T_final);
