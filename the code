%% 10. FEATURE SELECTION & FULL REPORTING (Filter, Wrapper, Embedded)
fprintf('\n============================================================\n');
fprintf('STARTING FEATURE SELECTION & REPORTING\n');
fprintf('============================================================\n');

num_features = size(X_train, 2);
k_top = 20; % تعداد فیچرهای برتر برای گزارش و نمودار

% ==========================================
% A. FILTER METHODS
% ==========================================

% --- 1. FDR (Fisher's Discriminant Ratio) ---
tic;
mu1 = mean(X_train(y_train == 1, :));
mu2 = mean(X_train(y_train == 2, :));
var1 = var(X_train(y_train == 1, :));
var2 = var(X_train(y_train == 2, :));

fdr_scores = (mu1 - mu2).^2 ./ (var1 + var2 + 1e-10); 
[fdr_sorted, fdr_idx] = sort(fdr_scores, 'descend');
time_fdr = toc;

fprintf('\n>>> 1. FDR (Fisher''s Discriminant Ratio) <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_fdr);
fprintf('Number of features selected: %d\n', k_top);
T_fdr = table(fdr_idx(1:k_top)', fdr_sorted(1:k_top)', 'VariableNames', {'Feature_ID', 'FDR_Score'});
disp(T_fdr);

% --- 2. Mutual Information (MI) ---
tic;
mi_scores = zeros(1, num_features);
p_y1 = sum(y_train==1) / length(y_train);
p_y2 = sum(y_train==2) / length(y_train);
H_Y = -p_y1*log2(p_y1) - p_y2*log2(p_y2); 

for i = 1:num_features
    edges = linspace(min(X_train(:,i)), max(X_train(:,i)), 11);
    bins = discretize(X_train(:,i), edges);
    H_Y_given_X = 0;
    for b = 1:10
        idx_b = (bins == b);
        p_x = sum(idx_b) / length(y_train);
        if p_x > 0
            p_y1_given_x = sum(y_train(idx_b)==1) / sum(idx_b);
            p_y2_given_x = sum(y_train(idx_b)==2) / sum(idx_b);
            h_temp = 0;
            if p_y1_given_x > 0, h_temp = h_temp - p_y1_given_x*log2(p_y1_given_x); end
            if p_y2_given_x > 0, h_temp = h_temp - p_y2_given_x*log2(p_y2_given_x); end
            H_Y_given_X = H_Y_given_X + p_x * h_temp;
        end
    end
    mi_scores(i) = H_Y - H_Y_given_X; 
end
[mi_sorted, mi_idx] = sort(mi_scores, 'descend');
time_mi = toc;

fprintf('\n>>> 2. Mutual Information (MI) <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_mi);
fprintf('Number of features selected: %d\n', k_top);
T_mi = table(mi_idx(1:k_top)', mi_sorted(1:k_top)', 'VariableNames', {'Feature_ID', 'MI_Score'});
disp(T_mi);

% --- 3. mRMR (minimum Redundancy Maximum Relevance) ---
tic;
[mrmr_idx, mrmr_scores] = fscmrmr(X_train, y_train);
mrmr_sorted = mrmr_scores(mrmr_idx);
time_mrmr = toc;

fprintf('\n>>> 3. mRMR <<<\n');
fprintf('Computational Time: %.3f seconds\n', time_mrmr);
fprintf('Number of features selected: %d\n', k_top);
T_mrmr = table(mrmr_idx(1:k_top)', mrmr_sorted(1:k_top)', 'VariableNames', {'Feature_ID', 'mRMR_Score'});
