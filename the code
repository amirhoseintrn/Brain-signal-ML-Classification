% --- 1. LASSO (L1 Regularization) ---
tic;
y_train_bin = (y_train == 2); 

% تنظیمات بهینه‌تر
opts = statset('MaxIter', 10000);  % افزایش منطقی iteration

% بازه کنترل‌شده Lambda (به جای NumLambda خام)
