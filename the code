% LOCAL FUNCTION (Must remain at the bottom of the file)
% ============================================================
function features = process_channel(segment, fs, bands)
    mean_val = mean(segment);
    std_val = std(segment);
    median_val = median(segment);
    skew_val = skewness(segment);
    kurt_val = kurtosis(segment);
    rms_val = rms(segment);
    zcr_val = mean(diff(sign(segment)) ~= 0);
    
    var0 = var(segment);
    dx = diff(segment);
    var1 = var(dx);
    ddx = diff(dx);
    var2 = var(ddx);
    
    activity = var0;
    mobility = 0;
    complexity = 0;
    
    if var0 > 0, mobility = sqrt(var1 / var0); end
    if var1 > 0 && mobility > 0, complexity = sqrt(var2 / var1) / mobility; end
    
    [counts, ~] = histcounts(segment, 50);
    prob = counts / sum(counts);
    prob(prob == 0) = [];
    shannon = -sum(prob .* log2(prob));
    
    nperseg = min(256, length(segment));
    [Pxx, f] = pwelch(segment, nperseg, [], nperseg, fs);
    
    Pxx_norm = Pxx / (sum(Pxx) + 1e-10);
    Pxx_norm(Pxx_norm == 0) = [];
    spec_entropy = -sum(Pxx_norm .* log2(Pxx_norm));
    
    apen = 0; sampen = 0; permen = 0;
    
    bandNames = fieldnames(bands);
    band_powers = zeros(1, length(bandNames));
    for b = 1:length(bandNames)
        band = bands.(bandNames{b});
        idx = (f >= band(1)) & (f <= band(2));
        if any(idx), band_powers(b) = trapz(f(idx), Pxx(idx));
        else, band_powers(b) = 0; end
    end
    
    features = [mean_val, std_val, median_val, skew_val, kurt_val, rms_val, zcr_val, ...
                activity, mobility, complexity, shannon, spec_entropy, ...
                apen, sampen, permen, band_powers];
end
